# Production Backend Configuration Variables

# Server
NODE_ENV=production

# Database
MONGO_URI=[SECRET PRODUCTION ATLAS CONNECTION STRING]

# JWT
JWT_SECRET=[CRYPTOGRAPHICALLY STRONG SECRET > 32 CHARS]

# CORS (Do NOT include trailing slash)
FRONTEND_URL=https://yourdomain.com
ADDITIONAL_ALLOWED_ORIGINS=https://www.yourdomain.com

# Cloudinary Uploads (Production persistence)
CLOUDINARY_CLOUD_NAME=[YOUR CLOUDINARY CLOUD NAME]
CLOUDINARY_API_KEY=[YOUR CLOUDINARY API KEY]
CLOUDINARY_API_SECRET=[YOUR CLOUDINARY API SECRET]
